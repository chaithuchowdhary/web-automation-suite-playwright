# Copy to .env and fill in real values. .env is git-ignored.
# In CI these same names are provided as GitHub Actions secrets.

# Account registered on https://www.automationexercise.com
EMAIL=your_email@example.com
PASSWORD=your_password

# Dummy sandbox card used by the checkout tests - never charged.
CARD_NAME=Test User
CARD_NUMBER=4111111111111111
CARD_CVC=123
CARD_EXPIRY_MONTH=12
CARD_EXPIRY_YEAR=2030
